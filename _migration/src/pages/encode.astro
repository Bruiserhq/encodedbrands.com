---
import Base from "../layouts/Base.astro";
import { getEntry } from "astro:content";
const page = (await getEntry("pages", "encode"))!.data;
---
<Base title={page.title!} description={page.description!}>
<style is:global>
/* ================================================================
   DESIGN SYSTEM — shared with index.html
   ================================================================ */
:root {
  --paper:    #FAFAF6;
  --paper-2:  #F0EDE6;
  --ink:      #0F0F0D;
  --ink-2:    #2B2923;
  --ink-3:    #6B6560;
  --ink-4:    #928C85;
  --rule:     #0F0F0D;
  --rule-soft: rgba(15,15,13,.10);
  --accent:   #B33D2A;
  --accent-warm: #D48845;
  --moss:     #3B4A2A;
  --sky:      #2A3B5C;

  --sans:  'Space Grotesk', system-ui, -apple-system, sans-serif;
  --serif: 'Instrument Serif', Georgia, serif;
  --mono:  'IBM Plex Mono', 'SF Mono', Menlo, monospace;

  --container: 1280px;
  --gutter: clamp(20px, 4vw, 56px);
  --idx-col: 160px;
}

/* ================================================================
   RESET + BASE
   ================================================================ */
*, *::before, *::after { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--paper);
  color: var(--ink);
  font-family: var(--sans);
  font-size: 16px;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
}
body::before {
  content: "";
  position: fixed; inset: 0;
  pointer-events: none; z-index: 1;
  background: radial-gradient(ellipse at 20% -5%, rgba(179,61,42,.04), transparent 50%);
}
a { color: inherit; text-decoration: none; }
::selection { background: var(--accent); color: var(--paper); }

/* ================================================================
   LAYOUT
   ================================================================ */
.wrap {
  max-width: var(--container);
  margin: 0 auto;
  padding: 0 var(--gutter);
  position: relative;
  z-index: 5;
}

/* ================================================================
   BUTTONS
   ================================================================ */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 13px 20px;
  font-family: var(--mono);
  font-size: 13px;
  letter-spacing: .04em;
  border: 1px solid var(--ink);
  background: var(--ink);
  color: var(--paper);
  cursor: pointer;
  transition: background .2s ease, border-color .2s ease, transform .2s ease;
}
.btn:hover {
  background: var(--accent);
  border-color: var(--accent);
  transform: translateY(-1px);
}
.btn .arrow { transition: transform .2s ease; }
.btn:hover .arrow { transform: translateX(3px); }
.btn.ghost {
  background: transparent;
  color: var(--ink);
}
.btn.ghost:hover {
  background: var(--ink);
  color: var(--paper);
  border-color: var(--ink);
}
.btn.accent-bg {
  background: var(--accent);
  border-color: var(--accent);
}
.btn.accent-bg:hover {
  background: var(--ink);
  border-color: var(--ink);
}
.btn.big {
  padding: 18px 28px;
  font-size: 14px;
}

/* ================================================================
   NAV
   ================================================================ */
.nav {
  position: sticky; top: 0;
  z-index: 50;
  backdrop-filter: blur(12px) saturate(1.15);
  -webkit-backdrop-filter: blur(12px) saturate(1.15);
  background: rgba(250,250,246,.82);
  border-bottom: 1px solid var(--rule-soft);
}
.nav .wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
}
.nav-brand {
  display: flex;
  align-items: baseline;
  gap: 8px;
  font-family: var(--serif);
  font-weight: 400;
  font-size: 22px;
  letter-spacing: -.01em;
}
.nav-brand .bullet {
  width: 7px; height: 7px;
  background: var(--accent);
  border-radius: 50%;
  display: inline-block;
  translate: 0 -3px;
}
.nav-brand small {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .16em;
  color: var(--ink-3);
  text-transform: uppercase;
  font-weight: 400;
  margin-left: 8px;
}
.nav-links {
  display: flex;
  gap: 28px;
  align-items: center;
}
.nav-link {
  font-family: var(--mono);
  font-size: 12px;
  letter-spacing: .04em;
  color: var(--ink-2);
  position: relative;
}
.nav-link::after {
  content: "";
  position: absolute;
  left: 0; right: 100%;
  bottom: -4px; height: 1px;
  background: var(--ink);
  transition: right .3s ease;
}
.nav-link:hover::after { right: 0; }
.nav-link.active { color: var(--accent); }
.nav-cta {
  font-family: var(--mono);
  font-size: 12px;
  padding: 8px 14px;
  border: 1px solid var(--ink);
  transition: background .2s ease, color .2s ease;
}
.nav-cta:hover {
  background: var(--ink);
  color: var(--paper);
}
@media (max-width: 820px) {
  .nav-links { display: none; }
}

/* ================================================================
   PAGE HERO
   ================================================================ */
.page-hero {
  padding: clamp(48px, 8vh, 88px) 0 clamp(24px, 3vh, 40px);
}
.page-hero .meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--ink-3);
  padding-bottom: 20px;
  border-bottom: 1px solid var(--rule);
  gap: 20px;
  flex-wrap: wrap;
}
.page-hero h1 {
  font-family: var(--sans);
  font-weight: 500;
  font-size: clamp(44px, 7vw, 96px);
  line-height: .94;
  letter-spacing: -.03em;
  margin: 48px 0 0;
  max-width: 18ch;
}
.page-hero h1 em {
  font-family: var(--serif);
  font-style: italic;
  color: var(--accent);
  font-weight: 400;
}
.page-hero .lede {
  margin-top: 24px;
  max-width: 60ch;
  font-size: clamp(16px, 1.3vw, 19px);
  color: var(--ink-2);
  line-height: 1.55;
}
.page-hero .lede b { color: var(--ink); font-weight: 600; }

/* ================================================================
   TIER SECTIONS
   ================================================================ */
.tier-section {
  padding: clamp(56px, 8vh, 96px) 0;
  border-top: 1px solid var(--rule);
}
.tier-head {
  display: grid;
  grid-template-columns: var(--idx-col) minmax(0, 1fr);
  gap: 32px;
  align-items: baseline;
  margin-bottom: 40px;
}
@media (max-width: 700px) { .tier-head { grid-template-columns: 1fr; gap: 14px; } }
.tier-head .idx {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .16em;
  color: var(--accent);
  text-transform: uppercase;
  font-weight: 500;
}
.tier-head .price {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .1em;
  color: var(--ink-3);
  text-transform: uppercase;
  margin-top: 10px;
}
.tier-head h2 {
  font-family: var(--sans);
  font-weight: 500;
  font-size: clamp(32px, 4.4vw, 56px);
  letter-spacing: -.02em;
  margin: 0;
  line-height: 1.02;
}
.tier-head h2 em {
  font-family: var(--serif);
  font-style: italic;
  color: var(--accent);
  font-weight: 400;
}

.tier-body {
  display: grid;
  grid-template-columns: var(--idx-col) minmax(0, 1fr);
  gap: 32px;
}
@media (max-width: 700px) { .tier-body { grid-template-columns: 1fr; gap: 14px; } }
.tier-body .spacer {}
.tier-body p {
  color: var(--ink-2);
  font-size: 17px;
  line-height: 1.6;
  max-width: 64ch;
  margin: 0 0 16px;
}
.tier-body p b { color: var(--ink); font-weight: 600; }
.tier-body code {
  font-family: var(--mono);
  font-size: .92em;
  background: var(--paper-2);
  padding: 1px 6px;
  border: 1px solid var(--rule-soft);
}
.tier-body a.link {
  color: var(--accent);
  text-decoration: underline;
  text-underline-offset: 4px;
  text-decoration-thickness: 1px;
}
.tier-body a.link:hover { color: var(--ink); }

/* deliverable cards */
.deliverables {
  margin-top: 28px;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 14px;
}
.deliverable {
  padding: 22px 20px;
  background: var(--paper);
  border: 1px solid var(--ink);
  transition: transform .25s ease, box-shadow .25s ease;
}
.deliverable:hover {
  transform: translateY(-3px);
  box-shadow: 8px 8px 0 var(--ink);
}
.deliverable .tag {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--ink-3);
  margin-bottom: 8px;
}
.deliverable h4 {
  font-family: var(--sans);
  font-weight: 500;
  font-size: 18px;
  letter-spacing: -.01em;
  margin: 0 0 8px;
  line-height: 1.2;
}
.deliverable h4 em {
  font-family: var(--serif);
  font-style: italic;
  color: var(--accent);
  font-weight: 400;
}
.deliverable p {
  color: var(--ink-2);
  font-size: 14px;
  line-height: 1.5;
  margin: 0;
}

/* ================================================================
   COMPARISON TABLE
   ================================================================ */
.compare {
  margin-top: clamp(56px, 8vh, 96px);
  border-top: 1px solid var(--rule);
  padding-top: clamp(56px, 8vh, 96px);
}
.compare-head {
  display: grid;
  grid-template-columns: var(--idx-col) minmax(0, 1fr);
  gap: 32px;
  align-items: baseline;
  margin-bottom: 40px;
}
@media (max-width: 700px) { .compare-head { grid-template-columns: 1fr; gap: 14px; } }
.compare-head .idx {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .16em;
  color: var(--accent);
  text-transform: uppercase;
  font-weight: 500;
}
.compare-head h2 {
  font-family: var(--sans);
  font-weight: 500;
  font-size: clamp(28px, 3.6vw, 48px);
  letter-spacing: -.02em;
  margin: 0;
  line-height: 1.02;
}
.compare-head h2 em {
  font-family: var(--serif);
  font-style: italic;
  color: var(--accent);
  font-weight: 400;
}

.compare-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 15px;
}
.compare-table th {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--ink-3);
  font-weight: 500;
  text-align: left;
  padding: 14px 16px;
  border-bottom: 2px solid var(--ink);
  vertical-align: bottom;
}
.compare-table td {
  padding: 14px 16px;
  border-bottom: 1px solid var(--rule-soft);
  vertical-align: top;
  color: var(--ink-2);
}
.compare-table td:first-child {
  font-weight: 500;
  color: var(--ink);
  font-size: 14.5px;
}
.compare-table tr:last-child td { border-bottom: 2px solid var(--ink); }
.compare-table .check { color: var(--moss); font-weight: 600; }
.compare-table .dash { color: var(--ink-4); }
@media (max-width: 700px) {
  .compare-table { font-size: 13px; }
  .compare-table th, .compare-table td { padding: 10px 8px; }
}

/* ================================================================
   CLOSING CTA
   ================================================================ */
.closing {
  margin-top: clamp(72px, 10vh, 120px);
  padding: clamp(48px, 7vh, 88px) 0;
  background: var(--ink);
  color: var(--paper);
  position: relative;
  overflow: hidden;
}
.closing::before {
  content: "";
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse at 8% 8%, rgba(179,61,42,.1), transparent 50%),
    radial-gradient(ellipse at 92% 92%, rgba(42,59,92,.12), transparent 50%);
  pointer-events: none;
}
.closing .wrap { position: relative; z-index: 2; }
.closing h2 {
  font-family: var(--sans);
  font-weight: 500;
  font-size: clamp(28px, 4.2vw, 48px);
  letter-spacing: -.02em;
  line-height: 1.05;
  margin: 0;
  max-width: 24ch;
}
.closing h2 em {
  font-family: var(--serif);
  font-style: italic;
  color: var(--accent-warm);
  font-weight: 400;
}
.closing p {
  margin-top: 20px;
  color: rgba(250,250,246,.7);
  font-size: 16px;
  line-height: 1.6;
  max-width: 56ch;
}
.closing .ctas {
  margin-top: 28px;
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
.closing .btn.ghost {
  color: var(--paper);
  border-color: rgba(250,250,246,.4);
}
.closing .btn.ghost:hover {
  background: var(--paper);
  color: var(--ink);
  border-color: var(--paper);
}

/* ================================================================
   FOOTER
   ================================================================ */
footer {
  background: var(--ink);
  color: rgba(250,250,246,.7);
  padding: 72px 0 28px;
}
.foot-grid {
  display: grid;
  grid-template-columns: 2.5fr 1fr 1fr 1fr;
  gap: clamp(24px, 4vw, 56px);
}
@media (max-width: 820px) { .foot-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 520px) { .foot-grid { grid-template-columns: 1fr; } }

.foot-brand {
  font-family: var(--serif);
  font-size: clamp(56px, 12vw, 180px);
  line-height: .88;
  letter-spacing: -.04em;
  font-weight: 400;
  color: var(--paper);
}
.foot-brand .fdot {
  display: inline-block;
  width: .14em; height: .14em;
  background: var(--accent);
  border-radius: 50%;
  translate: 0 -.08em;
}
.foot-sub {
  margin-top: 18px;
  font-family: var(--mono);
  font-size: 12px;
  color: rgba(250,250,246,.5);
  letter-spacing: .1em;
  text-transform: uppercase;
}
.foot-col h5 {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--accent-warm);
  font-weight: 500;
  margin: 0 0 16px;
}
.foot-col ul {
  list-style: none;
  padding: 0; margin: 0;
  display: grid; gap: 10px;
  font-size: 14px;
}
.foot-col a { transition: color .2s ease; }
.foot-col a:hover { color: var(--accent-warm); }
.foot-bottom {
  margin-top: 72px;
  padding-top: 20px;
  border-top: 1px solid rgba(250,250,246,.1);
  display: flex;
  justify-content: space-between;
  gap: 12px; flex-wrap: wrap;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--ink-4);
}
.foot-bottom a:hover { color: var(--paper); }

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation: none !important; transition: none !important; }
}
</style>

<header class="page-hero">
  <div class="wrap">
    <div class="meta">
      <span>{page.meta_left}</span>
      <span>{page.meta_right}</span>
    </div>
    <h1 set:html={page.hero_heading}></h1>
    <p class="lede" set:html={page.hero_lede}></p>
  </div>
</header>

{page.tiers?.map((t: any) => (
  <section class="tier-section" id={t.id}>
    <div class="wrap">
      <div class="tier-head">
        <div>
          <div class="idx">{t.idx}</div>
          <div class="price">{t.price}</div>
        </div>
        <h2 set:html={t.heading}></h2>
      </div>
      <div class="tier-body">
        <div class="spacer"></div>
        <div>
          {t.intros?.map((p: any) => <p set:html={p.text}></p>)}

          <div class="deliverables">
            {t.deliverables?.map((d: any) => (
              <div class="deliverable">
                <div class="tag">{d.tag}</div>
                <h4 set:html={d.title}></h4>
                <p set:html={d.body}></p>
              </div>
            ))}
          </div>

          <div style="margin-top:28px;display:flex;gap:12px;flex-wrap:wrap">
            {t.ctas?.map((c: any) => (
              <a
                class={`btn${c.ghost ? " ghost" : " accent-bg"}`}
                href={c.href}
                {...(c.href?.startsWith("http") ? { target: "_blank", rel: "noopener" } : {})}
              >
                {c.label}{!c.ghost && <> <span class="arrow">→</span></>}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
))}

<!-- COMPARISON TABLE -->
<section class="compare">
  <div class="wrap">
    <div class="compare-head">
      <div class="idx">{page.compare_idx}</div>
      <h2 set:html={page.compare_heading}></h2>
    </div>

    <div style="overflow-x:auto">
      <table class="compare-table">
        <thead>
          <tr>
            <th style="min-width:200px"></th>
            <th>{page.compare_head_free}</th>
            <th>{page.compare_head_session}</th>
            <th>{page.compare_head_sprint}</th>
          </tr>
        </thead>
        <tbody>
          {page.compare_rows?.map((r: any) => (
            <tr>
              <td>{r.label}</td>
              <td class={r.free === "✓" ? "check" : r.free === "—" ? "dash" : ""}>{r.free}</td>
              <td class={r.session === "✓" ? "check" : r.session === "—" ? "dash" : ""}>{r.session}</td>
              <td class={r.sprint === "✓" ? "check" : r.sprint === "—" ? "dash" : ""}>{r.sprint}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- ENCODER WAITLIST -->
<section class="tier-section" style="border-top:1px solid var(--rule)">
  <div class="wrap">
    <div class="tier-head">
      <div>
        <div class="idx">{page.encoder_idx}</div>
        <div class="price">{page.encoder_price}</div>
      </div>
      <h2 set:html={page.encoder_heading}></h2>
    </div>
    <div class="tier-body">
      <div class="spacer"></div>
      <div>
        {(page.encoder_body ?? "").split("\n\n").map((para: string) => <p set:html={para}></p>)}
      </div>
    </div>
  </div>
</section>

<!-- CLOSING CTA -->
<section class="closing">
  <div class="wrap">
    <h2 set:html={page.closing_heading}></h2>
    <p set:html={page.closing_body}></p>
    <div class="ctas">
      {page.closing_ctas?.map((c: any) => (
        <a class={`btn big${c.ghost ? " ghost" : " accent-bg"}`} href={c.href}>
          {c.label}{!c.ghost && <> <span class="arrow">→</span></>}
        </a>
      ))}
    </div>
  </div>
</section>

<!-- FOOTER -->
</Base>
