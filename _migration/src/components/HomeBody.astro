---
import { getEntry } from "astro:content";

interface Props {
  brandYaml: string;
  voicePreview: string;
}
const { brandYaml, voicePreview } = Astro.props as Props;

const thesis = (await getEntry("homepage", "thesis"))!.data;
const surfaces = (await getEntry("homepage", "surfaces"))!.data;
const how = (await getEntry("homepage", "how"))!.data;
const pricing = (await getEntry("homepage", "pricing"))!.data;
const tech = (await getEntry("homepage", "tech"))!.data;
const manifesto = (await getEntry("homepage", "manifesto"))!.data;
const dogfood = (await getEntry("homepage", "dogfood"))!.data;
const launch = (await getEntry("homepage", "launch"))!.data;
---
<section id="thesis" class="section">
  <div class="wrap">
    <div class="section-head">
      <div class="idx">{thesis.idx}</div>
      <h2 set:html={thesis.heading}></h2>
    </div>

    <div class="idx-grid" style="margin-top:56px">
      <div class="section-idx">{thesis.lede_idx}</div>
      <p class="lede" set:html={(thesis.lede ?? "").replace(/\n/g, "<br/>")}></p>
    </div>

    <div class="idx-grid" style="margin-top:56px">
      <div class="section-idx">{thesis.body_idx}</div>
      <div class="body-text">
        {thesis.body_paragraphs?.map((p: any) => <p set:html={p.text}></p>)}
      </div>
    </div>

    {thesis.quote && (
      <div class="idx-grid pull-quote" style="margin-top:64px">
        <div class="section-idx">{thesis.quote_idx}</div>
        <div>
          <blockquote set:html={thesis.quote}></blockquote>
        </div>
      </div>
    )}
  </div>
</section>

<hr class="section-rule"/>

<section id="surfaces" class="section">
  <div class="wrap">
    <div class="section-head">
      <div class="idx">{surfaces.idx}</div>
      <h2 set:html={surfaces.heading}></h2>
    </div>

    <p class="smallprint" style="margin-top:28px;max-width:62ch">{surfaces.blurb}</p>

    <div class="surfaces">
      {surfaces.cards?.map((c: any) => (
        <div class="surface">
          <div class="num">{c.num}</div>
          <h3 set:html={c.title}></h3>
          <p set:html={c.body}></p>
          <div class="examples">
            {c.chips?.map((chip: any) => <span class="chip">{chip.text}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section id="how" class="section" style="padding-top:0">
  <div class="wrap">
    <div class="section-head">
      <div class="idx">{how.idx}</div>
      <h2 set:html={how.heading}></h2>
    </div>

    <ol class="steps">
      {how.steps?.map((s: any, i: number) => (
        <li>
          <div class="step-n">{String(i + 1).padStart(2, "0")}</div>
          <div>
            <h3 set:html={s.title}></h3>
            <p set:html={s.body}></p>
          </div>
        </li>
      ))}
    </ol>

    <div style="margin-top:40px;display:flex;gap:12px;flex-wrap:wrap">
      {how.cta_primary_label && (
        <a class="btn accent-bg" href={how.cta_primary_href}>{how.cta_primary_label} <span class="arrow">→</span></a>
      )}
      {how.cta_secondary_label && (
        <a class="btn ghost" href={how.cta_secondary_href}>{how.cta_secondary_label}</a>
      )}
    </div>
  </div>
</section>

<section id="pricing" class="section" style="padding-top:0">
  <div class="wrap">
    <div class="section-head">
      <div class="idx">{pricing.idx}</div>
      <h2 set:html={pricing.heading}></h2>
    </div>

    <p class="smallprint" style="margin-top:28px;max-width:62ch">{pricing.blurb}</p>

    <div class="pricing">
      {pricing.tiers?.map((t: any) => (
        <div class={`tier${t.popular ? " popular" : ""}`}>
          {t.popular && <div class="tier-badge">Most popular</div>}
          <div class="tier-tag">{t.tag}</div>
          <div class="tier-price"><span class="num">{t.price_num}</span><span class="per">{t.price_per}</span></div>
          <h3 set:html={t.title}></h3>
          <p set:html={t.body}></p>
          <ul class="tier-list">
            {t.features?.map((f: any) => <li set:html={f.text}></li>)}
          </ul>
          <a class={`btn${t.cta_accent ? " accent-bg" : " ghost"}`} href={t.cta_href}>{t.cta_label} <span class="arrow">→</span></a>
        </div>
      ))}
    </div>

    {pricing.footer && (
      <p class="smallprint" style="margin-top:28px;max-width:62ch" set:html={pricing.footer}></p>
    )}
  </div>
</section>

<section id="protocol" class="section" style="padding-top:0">
  <div class="wrap">
    <div class="section-head">
      <div class="idx">{tech.idx}</div>
      <h2 set:html={tech.heading}></h2>
    </div>

    <p class="smallprint" style="margin-top:28px;max-width:62ch">{tech.blurb}</p>

    <aside class="dark-card" style="margin-top:36px" aria-label="Live brand.md frontmatter">
      <div class="dark-card-head">
        <span>{tech.card_title}</span>
        <span>{tech.card_meta}</span>
      </div>
      <pre>{brandYaml}</pre>
    </aside>

    {tech.footer && (
      <p class="smallprint" style="margin-top:28px;max-width:62ch" set:html={tech.footer}></p>
    )}
  </div>
</section>

<section class="manifesto">
  <div class="wrap">
    <p class="eyebrow"><span class="dot" aria-hidden="true"></span>&nbsp;{manifesto.eyebrow}</p>

    <div class="idx-grid" style="margin-top:36px">
      <div class="section-idx">{manifesto.idx}</div>
      <div>
        <blockquote
          style="font-family:var(--serif);font-size:clamp(28px,3.2vw,44px);line-height:1.2;margin:0;font-style:italic"
          set:html={manifesto.quote}
        ></blockquote>
      </div>
    </div>
  </div>
</section>

<section id="dogfood" class="section">
  <div class="wrap">
    <div class="section-head">
      <div class="idx">{dogfood.idx}</div>
      <h2 set:html={dogfood.heading}></h2>
    </div>

    <div class="dogfood">
      <div class="dogfood-left">
        <div class="kicker">{dogfood.kicker}</div>
        <h3 set:html={dogfood.sub_heading}></h3>
        {dogfood.body_paragraphs?.map((p: any) => <p set:html={p.text}></p>)}
        <div class="meta">
          {dogfood.meta?.map((m: any) => <span set:html={m.text}></span>)}
        </div>
        <div style="margin-top:34px;display:flex;gap:12px;flex-wrap:wrap">
          {dogfood.cta_primary_label && (
            <a class="btn" href={dogfood.cta_primary_href}>{dogfood.cta_primary_label} <span class="arrow">→</span></a>
          )}
          {dogfood.cta_secondary_label && (
            <a class="btn ghost" href={dogfood.cta_secondary_href} target="_blank" rel="noopener">{dogfood.cta_secondary_label}</a>
          )}
        </div>
      </div>

      <div class="code-block" aria-label="voice.md preview, live">
        <div class="code-head">
          <span class="dots" aria-hidden="true"><i></i><i></i><i></i></span>
          <span>{dogfood.code_card_title}</span>
          <span>{dogfood.code_card_meta}</span>
        </div>
        <pre class="code-body">{voicePreview}</pre>
      </div>
    </div>
  </div>
</section>

<hr class="section-rule"/>

<section id="launch" class="launch">
  <div class="wrap">
    <div class="idx-grid" style="align-items:baseline">
      <div class="section-idx">{launch.idx}</div>
      <div>
        <p class="eyebrow"><span class="dot" aria-hidden="true"></span>&nbsp;{launch.eyebrow}</p>
        <h2 set:html={launch.heading}></h2>
        <p set:html={launch.body}></p>
        <div class="cta-row">
          {launch.cta_primary_label && (
            <a class="btn" href={launch.cta_primary_href}>{launch.cta_primary_label} <span class="arrow">→</span></a>
          )}
          {launch.cta_secondary_label && (
            <a class="btn ghost" href={launch.cta_secondary_href}>{launch.cta_secondary_label}</a>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .steps {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    gap: 32px;
  }
  .steps li {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 24px;
    align-items: start;
    padding: 28px 0;
    border-top: 1px solid var(--rule-soft);
  }
  .steps li:last-child { border-bottom: 1px solid var(--rule-soft); }
  .step-n {
    font-family: var(--mono);
    font-size: 14px;
    letter-spacing: 0.08em;
    color: var(--accent);
  }
  .steps h3 {
    font-family: var(--serif);
    font-size: clamp(22px, 2.2vw, 30px);
    font-style: italic;
    margin: 0 0 10px;
    line-height: 1.2;
  }
  .steps p { margin: 0; color: var(--ink-2); max-width: 60ch; }

  .pricing {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }
  @media (max-width: 900px) {
    .pricing { grid-template-columns: 1fr; }
  }
  .tier {
    position: relative;
    border: 1px solid var(--rule-soft);
    padding: 28px 26px 32px;
    background: var(--paper);
    display: flex;
    flex-direction: column;
  }
  .tier.popular {
    border-color: var(--ink);
    background: var(--paper-2);
  }
  .tier-badge {
    position: absolute;
    top: -12px;
    left: 26px;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 5px 10px;
  }
  .tier-tag {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .tier-price {
    margin: 14px 0 18px;
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .tier-price .num {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(34px, 3.6vw, 48px);
    line-height: 1;
  }
  .tier-price .per {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--ink-3);
  }
  .tier h3 {
    font-family: var(--serif);
    font-size: clamp(20px, 2vw, 26px);
    font-style: italic;
    margin: 0 0 10px;
  }
  .tier p { color: var(--ink-2); margin: 0 0 16px; }
  .tier-list {
    list-style: none;
    padding: 0;
    margin: 0 0 22px;
    font-family: var(--mono);
    font-size: 12px;
    line-height: 1.7;
    color: var(--ink-2);
  }
  .tier-list li::before {
    content: "›";
    color: var(--accent);
    margin-right: 10px;
  }
  .tier .btn { margin-top: auto; justify-content: center; }
</style>
