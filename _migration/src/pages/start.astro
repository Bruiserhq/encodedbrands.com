<script is:inline>
const FULL_PROMPT = JSON.parse(document.getElementById('fullPromptData').textContent);

function copyPrompt() {
  navigator.clipboard.writeText(FULL_PROMPT).then(() => {
    const btn = document.getElementById('copyBtn');
    const label = document.getElementById('copyLabel');
    btn.classList.add('copied');
    label.textContent = '✓ Copied — now paste it into any AI';
    setTimeout(() => {
      btn.classList.remove('copied');
      label.textContent = 'Copy to clipboard';
    }, 4000);
  }).catch(() => {
    const ta = document.createElement('textarea');
    ta.value = FULL_PROMPT;
    document.body.appendChild(ta);
    ta.select();
    try { document.execCommand('copy'); } catch(e) {}
    document.body.removeChild(ta);
    const label = document.getElementById('copyLabel');
    label.textContent = '✓ Copied';
  });
}

function expandPrompt() {
  const body = document.getElementById('promptBody');
  const btn = document.getElementById('expandBtn');
  const text = document.getElementById('promptText');
  if (body.classList.contains('expanded')) {
    body.classList.remove('expanded');
    btn.textContent = 'Show full prompt ↓';
    text.textContent = FULL_PROMPT.substring(0, 1800) + '\n\n[... and 9 more questions covering Values, Boundaries, Claims, and Representation. Full prompt is ~1,500 words — copy the whole thing and paste it into your AI of choice.]';
  } else {
    body.classList.add('expanded');
    btn.textContent = 'Collapse ↑';
    text.textContent = FULL_PROMPT;
  }
}
</script>
</Base>
